# ─── vLLM Server ──────────────────────────────────────────────────────────────
ROOT_PASSWORD=rootpass
#VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct-GPTQ-Int8
LLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct
# VLLM_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct-AWQ
# VLLM_MODEL=BugTraceAI/BugTraceAI-Apex-G4-26B-Q4
VLLM_GPU_MEMORY_UTILIZATION=0.96
VLLM_DTYPE=auto
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_DATA_PARALLEL_SIZE=1
VLLM_USE_FASTOKENS=1
VLLM_CPU_NUM_OF_RESERVED_CPU=8
VLLM_MAX_NUM_SEQ=375
VLLM_ALLOW_LONG_MAX_MODEL_LEN=65536
VLLM_MAX_NUM_BATCHED_TOKENS=16384
VLLM_LOGGING_LEVEL=WARNING

# Quantize options: choose from auto, bfloat16, float16, fp8, fp8_ds_mla, 
# fp8_e4m3, fp8_e5m2, fp8_inc, fp8_per_token_head, int8_per_token_head, nvfp4, 
# turboquant_3bit_nc, turboquant_4bit_nc, turboquant_k3v4_nc, turboquant_k8v4
#VLLM_KV_CACHE_QUANT=turboquant_k3v4_nc
VLLM_MAX_MODEL_LEN=65536
VLLM_HF_TOKEN="your-very-secret-token"

# ─── ROCm ─────────────────────────────────────────────────────────────────────
#HSA_OVERRIDE_GFX_VERSION=gfx1201
#HIP_VISIBLE_DEVICES=0
